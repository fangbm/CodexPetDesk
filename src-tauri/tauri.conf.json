{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Pet Desk",
  "version": "0.1.0",
  "identifier": "com.codexpet.desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Pet Desk",
        "width": 208,
        "height": 224,
        "minWidth": 208,
        "minHeight": 224,
        "maxWidth": 400,
        "maxHeight": 432,
        "transparent": true,
        "backgroundColor": "#00000000",
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "resizable": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
