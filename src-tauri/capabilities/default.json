{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default app capability for the pet and settings windows.",
  "windows": [
    "main",
    "settings"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "dialog:allow-open",
    "updater:default",
    "process:default"
  ]
}
